# =============================================================================
# PORTFOLIO CV — Variables de entorno
# =============================================================================
# Copia este archivo a .env y ajusta los valores marcados como OBLIGATORIO.
# El resto tiene valores por defecto válidos para desarrollo local.
# El .env nunca se sube al repositorio.
# =============================================================================


# -----------------------------------------------------------------------------
# Aplicación
# -----------------------------------------------------------------------------
APP_NAME="Mi Portfolio"
APP_ENV=local                      # local | production
APP_DEBUG=true                     # false en producción
APP_KEY=                           # OBLIGATORIO — genera con: php artisan key:generate
APP_URL=http://localhost:8080

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12


# -----------------------------------------------------------------------------
# Base de datos — MariaDB
# -----------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=db                         # nombre del servicio en docker-compose
DB_PORT=3306
DB_DATABASE=portfolio
DB_USERNAME=portfolio
DB_PASSWORD=secret                 # OBLIGATORIO — cambia en producción
DB_ROOT_PASSWORD=rootsecret        # OBLIGATORIO — cambia en producción


# -----------------------------------------------------------------------------
# Proxy inverso (necesario si la app está detrás de Nginx, Traefik, NPM, etc.)
# -----------------------------------------------------------------------------
# Usa * para confiar en todos los proxies, o la IP concreta del proxy (ej: 192.168.1.150)
# En desarrollo local déjalo vacío o elimina la línea
TRUSTED_PROXIES=


# -----------------------------------------------------------------------------
# Docker (opcionales — solo si necesitas sobreescribir los valores por defecto)
# -----------------------------------------------------------------------------
# PORT=8080                        # puerto expuesto por nginx (por defecto 8080)
# APP_IMAGE=jflorido94/webportfolio-cv:latest    # imagen de la app
# NGINX_IMAGE=jflorido94/webportfolio-cv-nginx:latest  # imagen de nginx


# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug                    # info en producción


# -----------------------------------------------------------------------------
# Sesión, caché y colas
# -----------------------------------------------------------------------------
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
CACHE_PREFIX=


# -----------------------------------------------------------------------------
# Correo (solo si se usa — no requerido para funcionalidad básica)
# -----------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME=""


# -----------------------------------------------------------------------------
# Vite
# -----------------------------------------------------------------------------
VITE_APP_NAME=""
